{
    "name": "isoequal",
    "version": "0.1.0",
    "description": "Deep equality that actually handles cyclic structures and unordered collections \u2014 Sets, Maps, and anything declaring the unordered-collection protocol \u2014 under sound, sharing-sensitive isomorphism semantics.",
    "keywords": [
        "deep-equal",
        "equality",
        "isomorphism",
        "cyclic",
        "circular",
        "set",
        "map",
        "multiset",
        "unordered",
        "structural",
        "compare",
        "dequal"
    ],
    "license": "MIT",
    "author": "Xyra Sinclair",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/XyraSinclair/isoequal.git"
    },
    "type": "module",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/cjs/index.js"
        }
    },
    "main": "./dist/cjs/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "DESIGN.md"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.cjs.json && node -e \"require('fs').writeFileSync('dist/cjs/package.json', JSON.stringify({type: 'commonjs'}))\"",
        "test": "vitest run",
        "bench": "BENCH=1 vitest run src/isoequal.bench.test.ts",
        "release": "npm publish --access public",
        "prepublishOnly": "npm run test && npm run build"
    },
    "devDependencies": {
        "@types/node": "^26.1.0",
        "dequal": "^2.0.3",
        "fast-deep-equal": "^3.1.3",
        "lodash": "^4.17.21",
        "typescript": "^5.5.0",
        "vitest": "^1.6.0"
    },
    "module": "./dist/index.js"
}
